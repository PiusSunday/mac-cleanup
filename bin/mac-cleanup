#!/usr/bin/env bash
# bin/mac-cleanup — Entry point: flag parsing, orchestration, and final report
set -euo pipefail

# ── Resolve lib directory ─────────────────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIB_DIR="${SCRIPT_DIR}/../lib"

# ── Source core and utilities first ──────────────────────────────────────────
# shellcheck source=../lib/core/core.sh
source "${LIB_DIR}/core/core.sh"
# shellcheck source=../lib/core/utils.sh
source "${LIB_DIR}/core/utils.sh"
# shellcheck source=../lib/core/preflight.sh
source "${LIB_DIR}/core/preflight.sh"

# ── Source all modules ────────────────────────────────────────────────────────
# shellcheck source=../lib/modules/system/standard.sh
source "${LIB_DIR}/modules/system/standard.sh"
# shellcheck source=../lib/modules/system/deep.sh
source "${LIB_DIR}/modules/system/deep.sh"
# shellcheck source=../lib/modules/system/orphans.sh
source "${LIB_DIR}/modules/system/orphans.sh"
# shellcheck source=../lib/modules/system/brew.sh
source "${LIB_DIR}/modules/system/brew.sh"
# shellcheck source=../lib/modules/system/snapshots.sh
source "${LIB_DIR}/modules/system/snapshots.sh"

# shellcheck source=../lib/modules/user/standard.sh
source "${LIB_DIR}/modules/user/standard.sh"
# shellcheck source=../lib/modules/user/mail.sh
source "${LIB_DIR}/modules/user/mail.sh"
# shellcheck source=../lib/modules/user/browsers.sh
source "${LIB_DIR}/modules/user/browsers.sh"
# shellcheck source=../lib/modules/user/apps.sh
source "${LIB_DIR}/modules/user/apps.sh"

# shellcheck source=../lib/modules/dev/devtools.sh
source "${LIB_DIR}/modules/dev/devtools.sh"
# shellcheck source=../lib/modules/dev/xcode.sh
source "${LIB_DIR}/modules/dev/xcode.sh"
# shellcheck source=../lib/modules/dev/devops.sh
source "${LIB_DIR}/modules/dev/devops.sh"
# shellcheck source=../lib/modules/dev/docker.sh
source "${LIB_DIR}/modules/dev/docker.sh"

# shellcheck source=../lib/optimize/optimize.sh
source "${LIB_DIR}/optimize/optimize.sh"

# ── Help output ───────────────────────────────────────────────────────────────
show_help() {
  cat <<EOF

${BOLD}mac-cleanup v${VERSION}${RESET} — macOS Developer Storage Cleanup

${BOLD}USAGE:${RESET}
  mac-cleanup [targets] [options]

${BOLD}TARGETS:${RESET}
  --system, -S       Scan crash reports, .DS_Store, Trash, dev caches
  --system-deep, -z  Deep system cleanup for rotated logs and old diagnostics
  --xcode, -x        Clean Xcode DerivedData, Archives, DeviceSupport
  --docker, -d       Clean Docker containers, images, volumes, build cache
  --devtools, -D     Clean orphaned node_modules, Rust targets, __pycache__, Gradle, Flutter
  --snapshots, -s    Delete local Time Machine snapshots
  --caches, -c       Clear ~/Library/Caches, Zsh, Spotify, JetBrains, and app caches
  --mail, -m         Clean old Mail downloads and recent-item metadata
  --brew, -b         Run brew cleanup and autoremove
  --optimize, -O     Run system optimizations (DNS flush, LS rebuild, SQLite vacuum)
  --all, -a          Run all cleanup targets

${BOLD}OPTIONS:${RESET}
  --dry-run, -n      Preview what would be deleted (DEFAULT — no files removed)
  --yes, -y          Skip confirmation prompts and run live cleanup
  --clean-orphans    Delete orphan candidates after per-item confirmation
  --devops-reset     Run nuclear cleanup for Docker and developer ecosystems
  --include-ml-models Include HuggingFace/Ollama model caches during DevOps reset
  --show-log         Print operation log and exit
  --verbose, -v      Show detailed logs
  --help, -h         Show this help

${BOLD}EXAMPLES:${RESET}
  mac-cleanup --all                 Preview all cleanups (dry-run by default)
  mac-cleanup --all --yes           Clean everything, no prompts (live mode)
  mac-cleanup --xcode --docker      Preview Xcode + Docker cleanup
  mac-cleanup --system              Scan system artifacts only
  mac-cleanup --devtools            Find orphaned build artifacts
  mac-cleanup --devops-reset --yes  Nuclear cleanup of dev toolchain caches
  mac-cleanup --show-log            Show deletion operation log

${YELLOW}${WARN}  By default, mac-cleanup runs in DRY-RUN mode and will NOT delete anything.${RESET}
   To actually delete files, run without --dry-run. You will be prompted for
   confirmation unless --yes is also passed.

EOF
}

# ── Flag parsing ──────────────────────────────────────────────────────────────
parse_flags() {
  if [[ $# -eq 0 ]]; then
    DRY_RUN=true
    TARGET_SYSTEM=true
    TARGET_XCODE=true
    TARGET_DOCKER=true
    TARGET_DEVTOOLS=true
    TARGET_SNAPSHOTS=true
    TARGET_CACHES=true
    TARGET_BREW=true
    TARGET_MAIL=true
    TARGET_SYSTEM_DEEP=true
    TARGET_OPTIMIZE=false
    log::warn "No flags provided. Running --all --dry-run by default."
    return
  fi

  local explicit_dry_run=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --system|-S)
        TARGET_SYSTEM=true
        ;;
      --xcode|-x)
        TARGET_XCODE=true
        ;;
      --system-deep|-z)
        TARGET_SYSTEM_DEEP=true
        ;;
      --docker|-d)
        TARGET_DOCKER=true
        ;;
      --devtools|-D)
        TARGET_DEVTOOLS=true
        ;;
      --snapshots|-s)
        TARGET_SNAPSHOTS=true
        ;;
      --caches|-c)
        TARGET_CACHES=true
        ;;
      --mail|-m)
        TARGET_MAIL=true
        ;;
      --brew|-b)
        TARGET_BREW=true
        ;;
      --optimize|-O)
        TARGET_OPTIMIZE=true
        ;;
      --all|-a)
        TARGET_SYSTEM=true
        TARGET_XCODE=true
        TARGET_DOCKER=true
        TARGET_DEVTOOLS=true
        TARGET_SNAPSHOTS=true
        TARGET_CACHES=true
        TARGET_MAIL=true
        TARGET_SYSTEM_DEEP=true
        TARGET_BREW=true
        ;;
      --clean-orphans)
        CLEAN_ORPHANS=true
        ;;
      --devops-reset)
        DEVOPS_RESET_MODE=true
        ;;
      --include-ml-models)
        INCLUDE_ML_MODELS=true
        ;;
      --show-log)
        SHOW_OPERATION_LOG=true
        ;;
      --dry-run|-n)
        DRY_RUN=true
        explicit_dry_run=true
        ;;
      --yes|-y)
        SKIP_CONFIRM=true
        ;;
      --verbose|-v)
        VERBOSE=true
        ;;
      --help|-h)
        show_help
        exit 0
        ;;
      *)
        log::error "Unknown option: $1"
        show_help
        exit 1
        ;;
    esac
    shift
  done

  # Determine effective mode after all flags are parsed
  if [[ "${SHOW_OPERATION_LOG:-false}" == "true" ]]; then
    return
  fi

  if [[ "$explicit_dry_run" == "true" ]]; then
    # Explicit --dry-run — nothing to prompt
    DRY_RUN=true
  elif [[ "$SKIP_CONFIRM" == "true" ]]; then
    # --yes without --dry-run — proceed with live cleanup silently
    DRY_RUN=false
  else
    # Interactive: warn and prompt
    printf '\n%s%s  ⚠  You are about to delete files. This cannot be undone.%s\n' \
      "${BOLD}" "${YELLOW}" "${RESET}"
    printf '   Run with --dry-run first to preview what will be removed.\n'
    printf '   Continue with live cleanup? [y/N]: '
    local _confirm
    read -r _confirm
    if [[ "$_confirm" =~ ^[Yy]$ ]]; then
      DRY_RUN=false
    else
      log::info "Aborted. Re-run with --dry-run to preview safely."
      exit 0
    fi
  fi
}

# ── Print upgraded summary report ─────────────────────────────────────────────
print_report() {
  local duration="$1"
  local disk_before="$2"
  local disk_after="$3"

  local mode_label="LIVE"
  if [[ "$DRY_RUN" == "true" ]]; then
    mode_label="DRY-RUN"
  fi

  local bar
  bar=$(printf '━%.0s' $(seq 1 53))

  # ── Header ──
  printf '\n%s%s%s%s\n' "${BOLD}" "${BLUE}" "$bar" "${RESET}"
  printf '%s  🧹 mac-cleanup — Summary Report%s\n' "${BOLD}" "${RESET}"
  printf '%s%s%s%s\n' "${BOLD}" "${BLUE}" "$bar" "${RESET}"
  printf '  Mode: %s%s%s  |  Duration: %ss\n\n' \
    "${CYAN}" "$mode_label" "${RESET}" "$duration"

  # ── Column headers ──
  local separator
  separator=$(printf '─%.0s' $(seq 1 77))
  printf '  %s%-18s %-15s %11s %13s   %s%s\n' \
    "${BOLD}" "Category" "Module" "Found" "Reclaimable" "Status" "${RESET}"
  printf '  %s\n' "$separator"

  # ── Per-module rows ──
  local total_scanned=0
  local total_projected=0
  local module_count=${#MODULE_NAMES[@]}

  if (( module_count == 0 )); then
    printf '  %s(no modules ran)%s\n' "${DIM}" "${RESET}"
  else
    local prev_category=""
    for (( i=0; i<module_count; i++ )); do
      local name="${MODULE_NAMES[$i]}"
      local category="${MODULE_CATEGORIES[$i]}"
      local scanned="${MODULE_SCANNED[$i]}"
      local status="${MODULE_STATUS[$i]}"
      local projected="${MODULE_PROJECTED[$i]:-0}"

      total_scanned=$(( total_scanned + scanned ))
      total_projected=$(( total_projected + projected ))

      local cat_display=""
      if [[ "$category" != "$prev_category" ]]; then
        cat_display="$category"
        prev_category="$category"
      fi

      local found_fmt="-"
      if (( scanned > 0 )); then
        found_fmt=$(utils::format_bytes "$scanned")
      fi

      local reclaimable_fmt="-"
      if (( projected > 0 )); then
        reclaimable_fmt=$(utils::format_bytes "$projected")
      elif [[ "$status" == "review" ]]; then
        reclaimable_fmt="0 B"
      fi

      local status_fmt="${GREEN}Clean${RESET}"
      case "$status" in
        skipped)
          status_fmt="${YELLOW}Skipped${RESET}"
          ;;
        review)
          status_fmt="${CYAN}Needs review${RESET}"
          ;;
      esac

      printf '  %-18s %-15s %11s %13s   %s\n' \
        "$cat_display" "$name" "$found_fmt" "$reclaimable_fmt" "$status_fmt"
    done
  fi

  # ── Total row ──
  printf '  %s\n' "$separator"

  local total_found_fmt total_reclaimable_fmt
  total_found_fmt=$(utils::format_bytes "$total_scanned")
  total_reclaimable_fmt=$(utils::format_bytes "$total_projected")

  printf '  %s%-18s %-15s %11s %13s%s\n' \
    "${BOLD}" "TOTALS" "" "$total_found_fmt" "$total_reclaimable_fmt" "${RESET}"

  # ── Footer ──
  printf '\n'
  local free_before_fmt free_after_fmt
  free_before_fmt=$(utils::format_bytes "$disk_before")
  free_after_fmt=$(utils::format_bytes "$disk_after")

  if [[ "$DRY_RUN" == "true" ]]; then
    local projected=$(( disk_before + total_projected ))
    local projected_fmt
    projected_fmt=$(utils::format_bytes "$projected")
    printf '  Free space:  %s → %s (projected)\n' "$free_before_fmt" "$projected_fmt"
  else
    printf '  Free space:  %s → %s\n' "$free_before_fmt" "$free_after_fmt"
  fi

  printf '  Log saved:   %s\n' "$LOG_FILE"
  printf '\n'
  printf '  %sStatus legend:%s\n' "${BOLD}" "${RESET}"
  printf '  - Needs review: found items are excluded from projected reclaimable bytes.\n'
  printf '  - Clean: module will be cleaned automatically in a real run.\n'
  printf '  - Skipped: prerequisite unavailable.\n'
  printf '%s%s%s%s\n\n' "${BOLD}" "${BLUE}" "$bar" "${RESET}"

  log::success "Run complete."
}

# ── Main ──────────────────────────────────────────────────────────────────────
main() {
  parse_flags "$@"

  if [[ "$SHOW_OPERATION_LOG" == "true" ]]; then
    utils::show_operation_log
    exit 0
  fi

  utils::check_macos
  utils::load_whitelist

  if [[ "$DRY_RUN" != "true" ]]; then
    preflight::run
  fi

  # Capture start time for duration tracking
  local start_time
  start_time=$(date +%s)

  # Show system context header
  utils::print_system_context

  # Live mode: show warning banner
  if [[ "$DRY_RUN" != "true" ]]; then
    printf '\n  %s%s  ⚠  LIVE MODE — files will be permanently deleted%s\n\n' \
      "${BOLD}" "${RED}" "${RESET}"
  fi

  # Snapshot free space before
  local disk_before
  disk_before=$(utils::get_free_bytes)

  # ── System (always runs first) ──
  log::category "System"
  system::clean
  [[ "$TARGET_SYSTEM_DEEP" == "true" ]] && system_deep::clean
  orphans::clean

  # ── Developer Tools ──
  if [[ "$TARGET_XCODE" == "true" ]] || [[ "$TARGET_DOCKER" == "true" ]] || [[ "$TARGET_DEVTOOLS" == "true" ]]; then
    log::category "Developer Tools"
    [[ "$TARGET_XCODE" == "true" ]]    && xcode::clean
    [[ "$TARGET_DOCKER" == "true" ]]   && docker::clean
    [[ "$TARGET_DEVTOOLS" == "true" ]] && devtools::clean
  fi

  # ── Caches & Logs ──
  if [[ "$TARGET_CACHES" == "true" ]] || [[ "$TARGET_BREW" == "true" ]] || [[ "$TARGET_MAIL" == "true" ]]; then
    log::category "Caches & Logs"
    if [[ "$TARGET_CACHES" == "true" ]]; then
      caches::clean
      browsers::clean
      apps::clean
    fi
    [[ "$TARGET_MAIL" == "true" ]] && mail::clean
    [[ "$TARGET_BREW" == "true" ]]   && brew::clean
  fi

  if [[ "$DEVOPS_RESET_MODE" == "true" ]]; then
    log::category "Developer Tools"
    devops_reset::run
  fi

  # ── Storage Management ──
  if [[ "$TARGET_SNAPSHOTS" == "true" ]]; then
    log::category "Storage Management"
    snapshots::clean
  fi

  # ── Optimization ──
  if [[ "${TARGET_OPTIMIZE:-false}" == "true" ]]; then
    optimize::run
  fi

  # Snapshot free space after
  local disk_after
  disk_after=$(utils::get_free_bytes)

  # Calculate duration
  local end_time
  end_time=$(date +%s)
  local duration=$(( end_time - start_time ))

  print_report "$duration" "$disk_before" "$disk_after"
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
